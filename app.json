{
  "expo": {
    "name": "Affirm",
    "slug": "affirm",
    "scheme": "affirm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8ED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.affirm.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Affirm needs microphone access to record your affirmations in your own voice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDF8ED",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.affirm.app",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "Affirm needs microphone access to record your affirmations in your own voice."
        }
      ],
      "expo-font"
    ]
  }
}
